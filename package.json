{
  "name": "inventory-app",
  "version": "1.0.0",
  "description": "Inventory management application",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "node index.js",
    "build": "npm run --workspace=frontend build",
    "dev": "concurrently \"npm run --workspace=backend dev\" \"npm run --workspace=frontend start\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "body-parser": "^1.20.2",
    "methods": "^1.1.2",
    "path-to-regexp": "^6.2.1",
    "qs": "^6.11.2",
    "query-string": "^8.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
